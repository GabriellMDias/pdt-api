{
  "name": "pdt-monorepo",
  "private": true,
  "version": "2.1.0",
  "mobile": {
    "androidVersionCode": 10203
  },
  "description": "Monorepo com API NestJS, web React e app mobile Expo",
  "scripts": {
    "setup": "npm --prefix apps/api install && npm --prefix apps/web install && npm --prefix apps/mobile install",
    "db:migrate:api": "npm --prefix apps/api run db:migrate:deploy",
    "version:sync": "node scripts/version-manager.mjs sync",
    "version:set": "node scripts/version-manager.mjs set",
    "version:bump": "node scripts/version-manager.mjs bump",
    "mobile:buildcode:bump": "node scripts/version-manager.mjs mobile-buildcode:bump",
    "dev:api": "npm --prefix apps/api run start:dev",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:mobile": "npm --prefix apps/mobile run start",
    "build:api": "npm --prefix apps/api run build",
    "build:web": "npm --prefix apps/web run build",
    "build": "npm run build:api && npm run build:web",
    "test:api": "npm --prefix apps/api run test",
    "lint:api": "npm --prefix apps/api run lint",
    "lint:web": "npm --prefix apps/web run lint",
    "lint:mobile": "npm --prefix apps/mobile run lint",
    "docker:build": "docker compose -f infra/docker/docker-compose.yml build",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:up:build": "docker compose -f infra/docker/docker-compose.yml up --build -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "docker:down:volumes": "docker compose -f infra/docker/docker-compose.yml down -v"
  }
}
