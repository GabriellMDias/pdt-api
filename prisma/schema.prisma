generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  UserPermission UserPermission[]
  ArquivoAnalise ArquivoAnalise[]
}

model Store {
  id           Int      @id
  description  String?  @default("")
  storeName    String?  @default("")
  activeStatus Boolean? @default(false)
  cnpj         String   @unique

  expenses                Expense[]
  MonthlyResult           MonthlyResult[]
  ExpenseApportionment    ExpenseApportionment[]
  PreExpense              PreExpense[]
  PreExpenseApportionment PreExpenseApportionment[]
  ArquivoAnalise          ArquivoAnalise[]
}

model CostCenter {
  id           Int      @id
  description  String
  activeStatus Boolean? @default(false)

  Department              Department[]
  MonthlyResult           MonthlyResult[]
  ExpenseApportionment    ExpenseApportionment[]
  PreExpenseApportionment PreExpenseApportionment[]
}

model Department {
  id              Int    @id @default(autoincrement())
  costCenterId    Int
  description     String
  departmentVrId1 Int
  departmentVrId2 Int
  level           Int

  costCenter CostCenter @relation(fields: [costCenterId], references: [id])
}

model MonthlyResult {
  id                 Int      @id @default(autoincrement())
  storeId            Int
  costCenterId       Int
  date               DateTime @default(now())
  recBruta           Float
  devolucao          Float
  imposto            Float
  custo              Float
  embalagem          Float
  quebra             Float
  recCom             Float
  despesaPessoal     Float
  despesaOperacional Float

  store      Store      @relation(fields: [storeId], references: [id])
  costCenter CostCenter @relation(fields: [costCenterId], references: [id])
}

model Expense {
  id          Int      @id @default(autoincrement())
  storeId     Int
  date        DateTime
  description String
  value       Float

  store                Store                  @relation(fields: [storeId], references: [id])
  ExpenseApportionment ExpenseApportionment[]
}

model ExpenseApportionment {
  id               Int      @id @default(autoincrement())
  expenseId        Int
  costCenterId     Int
  storeId          Int
  percentage       Float?
  useParticipation Boolean?

  expense    Expense    @relation(fields: [expenseId], references: [id])
  costCenter CostCenter @relation(fields: [costCenterId], references: [id])
  store      Store      @relation(fields: [storeId], references: [id])
}

model PreExpenseApportionment {
  id               Int      @id @default(autoincrement())
  preExpenseId     Int
  costCenterId     Int
  storeId          Int
  percentage       Float?
  useParticipation Boolean?

  preExpense PreExpense @relation(fields: [preExpenseId], references: [id])
  costCenter CostCenter @relation(fields: [costCenterId], references: [id])
  store      Store      @relation(fields: [storeId], references: [id])
}

model PreExpense {
  id          Int    @id @default(autoincrement())
  storeId     Int
  description String

  store                   Store                     @relation(fields: [storeId], references: [id])
  PreExpenseApportionment PreExpenseApportionment[]
}

model Permission {
  id    Int              @id @default(autoincrement())
  code  String           @unique // Ex: "users:consultar"
  label String // Ex: "Consultar usuários"
  users UserPermission[]
}

model UserPermission {
  userId       Int
  permissionId Int

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([userId, permissionId])
}

model AnalysisType {
  id          Int           @id @default(autoincrement())
  code        String        @unique // Ex: "PIS_C100_C170"
  description String // Ex: "Validação de PIS entre C100 e C170"
  active      Boolean       @default(true)
  groupName        String @default("")

  
  analyses    SpedAnalise[]
}

model SpedAnalise {
  id               Int  @id @default(autoincrement())
  resultadoJson    Json
  analysisTypeId   Int
  arquivoAnaliseId Int

  analysisType   AnalysisType   @relation(fields: [analysisTypeId], references: [id])
  arquivoAnalise ArquivoAnalise @relation(fields: [arquivoAnaliseId], references: [id])
}

model StatusAnalise {
  id             Int              @id @default(autoincrement())
  descricao      String
  ArquivoAnalise ArquivoAnalise[]
}

model ArquivoAnalise {
  id              Int      @id @default(autoincrement())
  dataImportacao  DateTime @default(now())
  mesRef          DateTime
  arquivoNome     String
  userId          Int
  statusAnaliseId Int
  storeId       Int

  store         Store         @relation(fields: [storeId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  statusAnalise StatusAnalise @relation(fields: [statusAnaliseId], references: [id])
  SpedAnalise   SpedAnalise[]
}
